<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BinaryExplorer.Pages.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:BinaryExplorer.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CmpColumnHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Compare" />
        <TextBlock Grid.Row="1"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Pick two binaries and inspect them side by side." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <Button x:Name="LeftOpenButton" Click="OpenLeft_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    <TextBlock Text="Open left..." />
                </StackPanel>
            </Button>
            <TextBlock x:Name="LeftPathText" VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="No left file" />
            <ProgressRing x:Name="LeftRing" IsActive="False" Width="16" Height="16" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <Button x:Name="RightOpenButton" Click="OpenRight_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                    <TextBlock Text="Open right..." />
                </StackPanel>
            </Button>
            <TextBlock x:Name="RightPathText" VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Text="No right file" />
            <ProgressRing x:Name="RightRing" IsActive="False" Width="16" Height="16" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="12">
            <TextBlock VerticalAlignment="Center" Text="Inspector:" />
            <ComboBox x:Name="InspectorCombo"
                      MinWidth="220"
                      SelectionChanged="InspectorCombo_SelectionChanged" />
            <TextBlock x:Name="SummaryText"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="5" ColumnSpacing="12" Padding="0,4,0,4"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="32" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource CmpColumnHeader}" Text="Title" />
            <TextBlock Grid.Column="1" Style="{StaticResource CmpColumnHeader}" Text="Left" />
            <TextBlock Grid.Column="2" Style="{StaticResource CmpColumnHeader}" Text="Right" />
            <TextBlock Grid.Column="3" Style="{StaticResource CmpColumnHeader}" Text="" />
        </Grid>

        <ListView x:Name="RowList" Grid.Row="6" SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:ComparisonRow">
                    <Grid ColumnSpacing="12" Padding="0,8,0,8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind Title}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind LeftValue}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"
                                   VerticalAlignment="Top" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind RightValue}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"
                                   VerticalAlignment="Top" />
                        <Border Grid.Column="3"
                                Width="22" Height="22"
                                CornerRadius="11"
                                VerticalAlignment="Top"
                                Background="{x:Bind Indicator, Converter={StaticResource IndicatorBrush}}">
                            <TextBlock Text="{x:Bind Indicator}"
                                       FontWeight="SemiBold"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
