<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BinaryExplorer.Pages.DisassemblyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:analysis="using:BinaryExplorer.Analysis"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Disassembly (x86 / x64)" />
        <TextBlock x:Name="HeadlineText"
                   Grid.Row="1"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Click="Back_Click" ToolTipService.ToolTip="Back (Alt+Left)" Padding="8,4,8,4">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>
            <Button x:Name="ForwardButton" Grid.Column="1" Click="Forward_Click" ToolTipService.ToolTip="Forward (Alt+Right)" Padding="8,4,8,4">
                <FontIcon Glyph="&#xE72A;" FontSize="14" />
            </Button>
            <ComboBox Grid.Column="2"
                      x:Name="StartCombo"
                      PlaceholderText="Pick a starting symbol"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="StartCombo_SelectionChanged" />
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="RVA:" Margin="8,0,4,0" />
            <TextBox Grid.Column="4"
                     x:Name="OffsetInput"
                     FontFamily="Consolas"
                     PlaceholderText="0x1234 or 0n4660" />
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="N:" Margin="8,0,4,0" />
            <NumberBox Grid.Column="6"
                       x:Name="CountInput"
                       Value="128"
                       Minimum="1"
                       Maximum="4096"
                       SpinButtonPlacementMode="Compact" />
            <Button Grid.Column="7" Content="Go" Click="Go_Click" Margin="8,0,0,0" Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Mode:" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <ComboBox x:Name="ModeCombo" SelectedIndex="0" MinWidth="220">
                <ComboBoxItem Content="Single function (stop at ret)" />
                <ComboBoxItem Content="Multiple functions (skip ret padding)" />
                <ComboBoxItem Content="Raw — N instructions, no boundaries" />
            </ComboBox>
        </StackPanel>

        <InfoBar x:Name="StatusBar" Grid.Row="4" IsOpen="False" />

        <Grid Grid.Row="5" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Functions sidebar -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Padding="10,8,10,4" Text="Functions"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <AutoSuggestBox Grid.Row="1"
                                    Margin="8,4,8,8"
                                    x:Name="FunctionFilter"
                                    PlaceholderText="Filter functions"
                                    QueryIcon="Find"
                                    TextChanged="FunctionFilter_TextChanged" />
                    <ListView Grid.Row="2"
                              x:Name="FunctionList"
                              SelectionMode="Single"
                              SelectionChanged="FunctionList_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="analysis:FunctionInfo">
                                <Grid Padding="10,6,10,6" ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Width="6" Height="6"
                                               RadiusX="3" RadiusY="3"
                                               VerticalAlignment="Center"
                                               Fill="{x:Bind Confirmed, Converter={StaticResource ConfirmedToBrush}}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{x:Bind Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontFamily="Consolas"
                                                   FontSize="13" />
                                        <TextBlock Text="{x:Bind Rva, Converter={StaticResource RvaToHex}}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Disasm output -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <ScrollViewer x:Name="AsmScroller"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <RichTextBlock x:Name="AsmBox"
                                       Padding="12"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       IsTextSelectionEnabled="True"
                                       TextWrapping="NoWrap" />
                    </ScrollViewer>
                    <TextBlock x:Name="StatusMessage"
                               Padding="16"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               VerticalAlignment="Top"
                               Text="Pick a function on the left or enter an RVA, then click Go." />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
