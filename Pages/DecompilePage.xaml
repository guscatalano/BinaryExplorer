<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BinaryExplorer.Pages.DecompilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Decompile (C#)" />
        <TextBlock x:Name="HeadlineText"
                   Grid.Row="1"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <AutoSuggestBox x:Name="TypeFilter"
                                    Margin="4,4,4,8"
                                    PlaceholderText="Filter types/methods"
                                    QueryIcon="Find"
                                    TextChanged="TypeFilter_TextChanged" />
                    <muxc:TreeView Grid.Row="1"
                                   x:Name="TypeTree"
                                   xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
                                   ItemInvoked="TypeTree_ItemInvoked" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <ScrollViewer x:Name="CodeScroller"
                                  HorizontalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="CodeBox"
                                   Padding="12"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   IsTextSelectionEnabled="True"
                                   TextWrapping="NoWrap"
                                   Text="Pick a method on the left to decompile." />
                    </ScrollViewer>
                    <TextBlock x:Name="StatusText"
                               Padding="16"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               VerticalAlignment="Top" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
