<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BinaryExplorer.Pages.ResourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BinaryExplorer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Resources" />
        <TextBlock x:Name="HeadlineText"
                   Grid.Row="1"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <TreeView x:Name="ResTree" ItemInvoked="ResTree_ItemInvoked" />
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="12,10,12,4">
                        <TextBlock x:Name="ResHeader" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Pick a resource on the left" />
                        <TextBlock x:Name="ResSubHeader"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <controls:HexView x:Name="HexPane" />
                        <ScrollViewer x:Name="TextScroller" Visibility="Collapsed">
                            <TextBlock x:Name="TextPane"
                                       Padding="12"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       IsTextSelectionEnabled="True"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
