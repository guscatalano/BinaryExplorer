<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="BinaryExplorer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BinaryExplorer"
    xmlns:controls="using:BinaryExplorer.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <controls:NullToVisibilityConverter x:Key="NullToVisibility" />
            <controls:ConfirmedToBrushConverter x:Key="ConfirmedToBrush" />
            <controls:RvaToHexConverter x:Key="RvaToHex" />
            <controls:IndicatorBrushConverter x:Key="IndicatorBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
